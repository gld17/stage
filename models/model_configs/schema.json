{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "STAGE Model Config",
  "type": "object",
  "required": [
    "model_name",
    "model_type",
    "display_name",
    "vocab_size",
    "hidden_size",
    "intermediate_size",
    "num_hidden_layers",
    "num_attention_heads",
    "num_key_value_heads",
    "experts",
    "kexperts",
    "vision_hidden_size",
    "vision_num_hidden_layers",
    "vision_num_attention_heads",
    "vision_intermediate_size",
    "vision_image_size",
    "vision_patch_size",
    "vision_in_channels",
    "vision_projection_size",
    "notes"
  ],
  "properties": {
    "model_name": {"type": "string"},
    "model_type": {"type": "string", "enum": ["dense", "gpt", "moe", "vlm"]},
    "display_name": {"type": "string"},
    "vocab_size": {"type": "integer"},
    "hidden_size": {"type": "integer"},
    "intermediate_size": {"type": "integer"},
    "num_hidden_layers": {"type": "integer"},
    "num_attention_heads": {"type": "integer"},
    "num_key_value_heads": {"type": "integer"},
    "experts": {"type": "integer"},
    "kexperts": {"type": "integer"},
    "head_dim": {"type": "integer"},
    "vision_hidden_size": {"type": "integer"},
    "vision_num_hidden_layers": {"type": "integer"},
    "vision_num_attention_heads": {"type": "integer"},
    "vision_intermediate_size": {"type": "integer"},
    "vision_image_size": {"type": "integer"},
    "vision_patch_size": {"type": "integer"},
    "vision_in_channels": {"type": "integer"},
    "vision_projection_size": {"type": "integer"},
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": false
}
