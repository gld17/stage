{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FlexET model configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_name",
    "model_type",
    "display_name",
    "vocab_size",
    "hidden_size",
    "intermediate_size",
    "num_hidden_layers",
    "num_attention_heads",
    "num_key_value_heads",
    "experts",
    "kexperts",
    "vision_hidden_size",
    "vision_num_hidden_layers",
    "vision_num_attention_heads",
    "vision_intermediate_size",
    "vision_image_size",
    "vision_patch_size",
    "vision_in_channels",
    "vision_projection_size",
    "notes"
  ],
  "properties": {
    "model_name": {"type": "string"},
    "model_type": {"type": "string", "enum": ["dense", "gpt", "moe", "vlm"]},
    "display_name": {"type": "string"},
    "vocab_size": {"type": "integer", "minimum": 1},
    "hidden_size": {"type": "integer", "minimum": 1},
    "intermediate_size": {"type": "integer", "minimum": 1},
    "num_hidden_layers": {"type": "integer", "minimum": 1},
    "num_attention_heads": {"type": "integer", "minimum": 1},
    "num_key_value_heads": {"type": "integer", "minimum": 1},
    "experts": {"type": "integer", "minimum": 1},
    "kexperts": {"type": "integer", "minimum": 1},
    "head_dim": {"type": "integer", "minimum": 1},
    "vision_hidden_size": {"type": "integer", "minimum": 1},
    "vision_num_hidden_layers": {"type": "integer", "minimum": 1},
    "vision_num_attention_heads": {"type": "integer", "minimum": 1},
    "vision_intermediate_size": {"type": "integer", "minimum": 1},
    "vision_image_size": {"type": "integer", "minimum": 1},
    "vision_patch_size": {"type": "integer", "minimum": 1},
    "vision_in_channels": {"type": "integer", "minimum": 1},
    "vision_projection_size": {"type": "integer", "minimum": 1},
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
